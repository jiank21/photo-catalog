# ============================================================
# Photo Catalog — Environment Variables
# Copy to .env and fill in. All VITE_ vars are exposed to the
# browser (acceptable for personal use).
# ============================================================

# Supabase project
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Google AI Studio (Gemini 1.5 Flash) — https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIza...

# OpenRouter (fallback vision models) — https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-or-...

# Groq (fallback vision model, Llama 4 Scout) — https://console.groq.com
VITE_GROQ_API_KEY=gsk_...

# HuggingFace Inference API (fallback BLIP captioner) — https://huggingface.co/settings/tokens
VITE_HF_API_KEY=hf_...
